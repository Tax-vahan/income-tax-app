# ─────────────────────────────────────────────────────────────────────────────
# TDS Challan & PAN Verification - Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Browser Operation Mode
# Set to 'false' to visibly render the browsers during local development
HEADLESS=true

# TRACES Target Endpoint
TRACES_URL=https://traces.tdscpc.gov.in

# Maximum browser operation timeout in milliseconds (e.g., 30000 = 30 seconds)
TIMEOUT=30000

# PAN Verification Playwright Session Time-To-Live (seconds)
# Defines how long a cached authentication token remains valid
SESSION_TTL=1800

# Enable verbose traceback and debug logging output
DEBUG_MODE=true

# Main TaxVahan backend API — used only by /tds/api/v1/challan/verify to fetch
# manually entered challans (SectionCode/BookEntry filtering happens on our side).
# Not the TRACES portal above.
TAXVAHAN_API_BASE=https://api.taxvahan.com
TAXVAHAN_API_KEY=
